# ============ caijing18 配置文件 ============
# 复制此文件并重命名为 .env，然后修改以下配置

# ---------- Telegram 频道 URL（公共频道网页抓取） ----------
# 支持多个频道，用逗号分隔
TG_CHANNEL_URLS=https://t.me/s/XXXX
# TG_CHANNEL_URLS=https://t.me/s/XXX,https://t.me/s/XXX

# ---------- TB Bot Token（可选，若不用 Bot 方式可留空） ----------
TELEGRAM_BOT_TOKEN=

# ---------- 数据存储路径（Docker 环境使用默认值） ----------
DATABASE_PATH=data/finance_data.db
APP_DATA_DIR=data

# ---------- AI 配置（OpenAI 兼容 API） ----------
# 从 https://api.xxx 获取 API Key（可选，不配置则不会生成 AI 总结）
AI_API_KEY=sk-123
# AI API 基础地址
AI_BASE_URL=https://api.xxx.org/v1
# AI 模型名称
AI_MODEL=deepseek-v4-flash
# ---------- Web 服务配置 ----------
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# ---------- 代理配置（可选） ----------
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
