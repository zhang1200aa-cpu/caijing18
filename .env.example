# ============ caijing18 配置文件 ============
# 复制此文件并重命名为 .env，然后修改以下配置

# ---------- Telegram 频道 URL（公共频道网页抓取） ----------
# 支持多个频道，用逗号分隔
# TG_CHANNEL_URLS=https://t.me/s/your_channel
# TG_CHANNEL_URLS=https://t.me/s/channel1,https://t.me/s/channel2

# ---------- TB Bot Token（可选，若不用 Bot 方式可留空） ----------
TELEGRAM_BOT_TOKEN=

# ---------- 数据存储路径（Docker 环境使用默认值） ----------
DATABASE_PATH=data/finance_data.db
APP_DATA_DIR=data

# ---------- 数据保留与去重 ----------
DATA_RETENTION_DAYS=7
SIMILARITY_THRESHOLD=0.75

# ---------- 抓取间隔配置（分钟） ----------
# 默认 30 分钟，可通过管理后台动态修改
SCRAPE_INTERVAL_MINUTES=30

# ---------- AI 配置（OpenAI 兼容 API） ----------
# 从 AI 服务商获取 API Key（可选，不配置则不会生成 AI 总结）
AI_API_KEY=
# AI API 基础地址（OpenAI / DeepSeek / 通义千问等）
AI_BASE_URL=
# AI 模型名称（gpt-4o-mini / deepseek-chat / qwen-plus 等）
AI_MODEL=

# ---------- Web 服务配置 ----------
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# ---------- 代理配置（可选） ----------
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
